---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import FeaturedPosts from '../components/FeaturedPosts.astro';
import TechStack from '../components/TechStack.astro';
import NetworkingSection from '../components/NetworkingSection.astro';
import NixSystemsSection from '../components/NixSystemsSection.astro';
import AISolutionsSection from '../components/AISolutionsSection.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<Hero />
			<FeaturedPosts />
			<NetworkingSection />
			<NixSystemsSection />
			<AISolutionsSection />
			<TechStack />
			<Newsletter />
		</main>
		<Footer />
	</body>
</html>
