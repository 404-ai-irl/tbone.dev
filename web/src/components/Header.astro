---
import HeaderLink from './HeaderLink.astro';
import Moon from './Moon.astro';
import SocialIcons from './SocialIcons.astro';
import navLogoDark from '../assets/nav-logo-0.png';
import navLogoLight from '../assets/nav-logo-1.png';
---

<header transition:persist>
	<nav>
		<div class="brand">
			<a href="/">
				<img src={navLogoDark.src} alt="tbone.dev" class="nav-logo dark-logo" />
				<img src={navLogoLight.src} alt="tbone.dev" class="nav-logo light-logo" />
				<span class="brand-text">tbone.dev</span>
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<Moon />
		<SocialIcons size={28} grouped />
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0.5em 1em;
		background: linear-gradient(
			to bottom,
			rgba(240, 234, 214, 0.97) 0%,
			rgba(240, 234, 214, 0.88) 40%,
			rgba(240, 234, 214, 0.55) 70%,
			rgba(240, 234, 214, 0) 100%
		);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		transition: background 0.3s ease;
		position: relative;
	}

	:root:not(.light) header {
		background: linear-gradient(
			to bottom,
			rgba(14, 17, 24, 0.97) 0%,
			rgba(14, 17, 24, 0.88) 40%,
			rgba(14, 17, 24, 0.55) 70%,
			rgba(14, 17, 24, 0) 100%
		);
	}

	.brand {
		display: flex;
		align-items: center;
	}

	.brand a {
		display: flex;
		align-items: center;
		border-bottom: none;
		gap: 0.5rem;
	}

	.brand-text {
		font-weight: 600;
		font-size: 1.1rem;
		color: var(--heading-color);
		letter-spacing: 0.02em;
	}

	.nav-logo {
		height: 40px;
		width: auto;
		display: block;
	}

	.dark-logo {
		display: block;
	}

	.light-logo {
		display: none;
	}

	:root.light .dark-logo {
		display: none;
	}

	:root.light .light-logo {
		display: block;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	nav a {
		padding: 1em 0.5em;
		color: var(--heading-color);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}

	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	@media (max-width: 720px) {
		.nav-logo {
			height: 32px;
		}
	}
</style>
