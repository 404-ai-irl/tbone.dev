---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import logoImage from '../assets/logo.png';

// Fetch featured blog posts
const allPosts = await getCollection('blog');
const featuredPosts = allPosts
	.filter((post) => post.data.featured && !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<header>
	<nav>
		<div class="brand">
			<a href="/" class="logo-link" aria-label="Home">
				<Image src={logoImage} alt="tbone.dev" width={40} height={40} />
			</a>
			<h2><a href="/">{SITE_TITLE}</a></h2>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<div class="nav-dropdown">
				<a href="/blog" class="nav-link">Blog ▾</a>
				<div class="dropdown-menu">
					{featuredPosts.length > 0 ? (
						<>
							<div class="dropdown-header">Featured Posts</div>
							{featuredPosts.map((post) => (
								<a href={`/blog/${post.id}/`} class="dropdown-item">
									{post.data.title}
								</a>
							))}
							<hr class="dropdown-divider" />
							<a href="/blog" class="dropdown-item view-all">View All Posts →</a>
						</>
					) : (
						<>
							<div class="dropdown-header">Featured Posts</div>
							<div class="dropdown-item no-posts">No featured posts yet</div>
							<hr class="dropdown-divider" />
							<a href="/blog" class="dropdown-item view-all">View All Posts →</a>
						</>
					)}
				</div>
			</div>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<a href="https://twitter.com" target="_blank" aria-label="Twitter">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
			<a href="https://linkedin.com" target="_blank" aria-label="LinkedIn">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0.5em 1em;
		background: var(--bg-color);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		transition: background-color 0.3s ease;
	}

	:root:not(.light) header {
		background: #000000;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}

	.logo-link {
		display: flex;
		align-items: center;
		padding: 0;
		border-bottom: none !important;
	}

	.logo-link img {
		width: 40px;
		height: 40px;
		border-radius: 4px;
		object-fit: contain;
	}

	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--heading-color);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	nav a {
		padding: 1em 0.5em;
		color: var(--heading-color);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}

	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	.social-links,
	.social-links a {
		display: flex;
	}

	/* Dropdown Menu Styles */
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}

	.nav-dropdown {
		position: relative;
		display: inline-block;
	}

	.nav-link {
		padding: 1em 0.5em;
		color: var(--heading-color);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		cursor: pointer;
		display: inline-block;
	}

	.nav-dropdown:hover .nav-link {
		border-bottom-color: var(--accent);
	}

	.dropdown-menu {
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%) translateY(-10px);
		background: rgba(0, 0, 0, 0.85);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(184, 149, 106, 0.2);
		border-radius: 12px;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5),
		            0 0 20px rgba(184, 149, 106, 0.1);
		min-width: 280px;
		max-width: 320px;
		opacity: 0;
		visibility: hidden;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 1000;
		margin-top: 0.5em;
	}

	.nav-dropdown:hover .dropdown-menu {
		opacity: 1;
		visibility: visible;
		transform: translateX(-50%) translateY(0);
	}

	.nav-dropdown:focus-within .dropdown-menu {
		opacity: 1;
		visibility: visible;
		transform: translateX(-50%) translateY(0);
	}

	.dropdown-header {
		padding: 0.75em 1em;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: rgba(184, 149, 106, 0.7);
		font-weight: 500;
		border-bottom: 1px solid rgba(184, 149, 106, 0.15);
		background: rgba(184, 149, 106, 0.05);
	}

	.dropdown-item {
		display: block;
		padding: 0.75em 1em;
		color: rgba(255, 255, 240, 0.9);
		text-decoration: none;
		transition: all 0.2s ease;
		font-size: 0.9rem;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		border-bottom: none !important;
	}

	.dropdown-item:hover {
		background: rgba(184, 149, 106, 0.15);
		color: #FFFFF0;
		padding-left: 1.2em;
	}

	.dropdown-item.view-all {
		color: rgba(184, 149, 106, 0.9);
		font-weight: 500;
		font-size: 0.85rem;
	}

	.dropdown-item.view-all:hover {
		color: #B8956A;
	}

	.dropdown-item.no-posts {
		color: rgba(var(--gray), 0.6);
		font-style: italic;
		cursor: default;
	}

	.dropdown-item.no-posts:hover {
		background: transparent;
		padding-left: 1em;
	}

	.dropdown-divider {
		border: none;
		border-top: 1px solid rgba(184, 149, 106, 0.1);
		margin: 0.5em 0;
	}

	@media (max-width: 720px) {
		.social-links {
			display: none;
		}

		.brand {
			gap: 0.5em;
		}

		.dropdown-menu {
			left: 0;
			transform: translateX(0) translateY(-10px);
			min-width: 240px;
			max-width: 280px;
		}

		.nav-dropdown:hover .dropdown-menu {
			transform: translateX(0) translateY(0);
		}

		.dropdown-item {
			font-size: 0.85rem;
		}
	}
</style>
