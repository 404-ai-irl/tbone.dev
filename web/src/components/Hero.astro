---
import navLogoDark from '../assets/nav-logo-0.png';
import navLogoLight from '../assets/nav-logo-1.png';
---

<section class="hero">
	<div class="hero-overlay"></div>

	<div class="hero-body">
		<div class="hero-content" id="hero-content">
			<span class="greeting">Code. Consciousness. Craft.</span>
			<img src={navLogoDark.src} alt="tbone.dev" class="hero-logo dark-logo" />
			<img src={navLogoLight.src} alt="tbone.dev" class="hero-logo light-logo" />
			<p class="tagline">Thoughtful creator of clever systems and thinking machines</p>
			<p class="description">
				I build reliable infrastructure, explore the philosophy of AI, and design reproducible systems with Nix.
				This is where I write about what I learn.
			</p>
			<div class="cta-buttons">
				<a href="/blog" class="btn btn-primary">Read the Blog</a>
				<a href="/about" class="btn btn-secondary">About Me</a>
			</div>
		</div>
	</div>
</section>

<script>
	const heroContent = document.getElementById('hero-content') as HTMLElement;
	const hero = heroContent?.closest('.hero') as HTMLElement;

	function updateParallax() {
		if (!hero || !heroContent) return;
		const rect = hero.getBoundingClientRect();
		if (rect.bottom < 0 || rect.top > window.innerHeight) return;
		const progress = -rect.top;
		heroContent.style.transform = `translateY(${progress * -0.06}px)`;
	}

	const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const isMobile = window.matchMedia('(max-width: 720px)').matches;
	if (!prefersReduced && !isMobile) {
		window.addEventListener('scroll', updateParallax, { passive: true });
		updateParallax();
	}
</script>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		min-height: auto;
		display: flex;
		flex-direction: column;
		background: var(--bg-color);
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			160deg,
			rgba(14, 17, 24, 1) 0%,
			rgba(14, 17, 24, 0.95) 40%,
			rgba(14, 17, 24, 0.9) 70%,
			rgba(14, 17, 24, 1) 100%
		);
		z-index: 1;
		transition: background 0.4s ease;
	}

	:root.light .hero-overlay {
		background: linear-gradient(
			160deg,
			rgba(240, 234, 214, 1) 0%,
			rgba(240, 234, 214, 0.95) 40%,
			rgba(240, 234, 214, 0.9) 70%,
			rgba(240, 234, 214, 1) 100%
		);
	}

	.hero-body {
		position: relative;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 6rem 2rem 4rem;
	}

	.hero-content {
		max-width: 680px;
		text-align: center;
		will-change: transform;
	}

	.hero-logo {
		height: 160px;
		width: auto;
		display: block;
		margin: 1rem auto 1.5rem;
	}

	.dark-logo {
		display: block;
	}

	.light-logo {
		display: none;
	}

	:root.light .dark-logo {
		display: none;
	}

	:root.light .light-logo {
		display: block;
	}

	.greeting {
		font-size: 0.95rem;
		color: var(--accent);
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		display: block;
		margin-bottom: 1rem;
	}


	.tagline {
		font-size: 1.3rem;
		color: rgba(237, 228, 200, 0.75);
		margin: 0 0 1.25rem;
		font-style: italic;
		letter-spacing: 0.02em;
		transition: color 0.3s ease;
	}

	:root.light .tagline {
		color: rgba(60, 48, 32, 0.7);
	}

	.description {
		font-size: 1.05rem;
		color: rgba(210, 200, 178, 0.85);
		line-height: 1.75;
		margin: 0 0 2rem;
		max-width: 520px;
		margin-left: auto;
		margin-right: auto;
		transition: color 0.3s ease;
	}

	:root.light .description {
		color: rgba(60, 48, 32, 0.8);
	}

	.cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn {
		padding: 0.8rem 2.25rem;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.2s ease;
		letter-spacing: 0.03em;
	}

	.btn-primary {
		background: var(--accent);
		color: #0E1118;
		border: 1px solid rgba(212, 168, 50, 0.4);
		box-shadow: 0 4px 20px rgba(200, 120, 58, 0.35);
	}

	.btn-primary:hover {
		background: var(--accent-dark);
		color: #0E1118;
		transform: translateY(-2px);
		box-shadow: 0 6px 28px rgba(200, 120, 58, 0.55);
	}

	.btn-secondary {
		background: rgba(237, 228, 200, 0.07);
		color: rgba(237, 228, 200, 0.85);
		border: 1px solid rgba(237, 228, 200, 0.25);
		backdrop-filter: blur(4px);
	}

	.btn-secondary:hover {
		background: rgba(237, 228, 200, 0.14);
		border-color: rgba(237, 228, 200, 0.4);
		transform: translateY(-2px);
	}

	:root.light .btn-secondary {
		background: rgba(60, 48, 32, 0.07);
		color: rgba(60, 48, 32, 0.85);
		border-color: rgba(60, 48, 32, 0.25);
	}

	:root.light .btn-secondary:hover {
		background: rgba(60, 48, 32, 0.14);
		border-color: rgba(60, 48, 32, 0.4);
	}

	@media (max-width: 720px) {
		.hero-body {
			padding: 5rem 1.5rem 3rem;
		}

		.hero-content {
			text-align: left;
		}

		.cta-buttons {
			justify-content: flex-start;
		}

		.hero-logo {
			height: 120px;
		}

		.btn {
			width: 100%;
			max-width: 260px;
			text-align: center;
		}
	}
</style>
