---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import logoImage from '../assets/logo.png';
---

<section class="hero">
	<div class="hero-content">
		<span class="greeting">✨ The Gateway Stirs</span>
		<h1>tbone</h1>
		<p class="tagline">Keeper of the Ancient Archives</p>
		<p class="description">
			Beyond the veil of code and cipher, a portal stands ready to open.
			The mysteries within await those who dare to venture deeper into the unknown...
		</p>
		<div class="cta-buttons">
			<a href="/blog" class="btn btn-primary">Enter the Archives</a>
			<a href="/about" class="btn btn-secondary">Discover the Keeper</a>
		</div>
	</div>
	<div class="hero-visual" style={`background-image: url(${logoImage.src});`}></div>
</section>

<style>
	.hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
		min-height: 60vh;
		padding: 2rem 0;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.greeting {
		font-size: 1.2rem;
		color: var(--accent);
		font-weight: 500;
	}

	h1 {
		font-size: 4rem;
		font-weight: 700;
		margin: 0;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.tagline {
		font-size: 1.5rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	.description {
		font-size: 1.1rem;
		color: rgb(var(--gray-dark));
		line-height: 1.6;
		max-width: 90%;
	}

	.cta-buttons {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}

	.btn {
		padding: 0.75rem 2.5rem;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.2s ease;
		min-width: 200px;
		text-align: center;
	}

	.btn-primary {
		background: var(--accent);
		color: #1A1A1A; /* Charcoal on Bronze — per TheRoyalOrphan btn spec */
	}

	.btn-primary:hover {
		background: var(--accent-dark);
		color: #1A1A1A;
		transform: translateY(-2px);
	}

	.btn-secondary {
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
	}

	.btn-secondary:hover {
		background: rgb(var(--gray));
		color: white;
	}

	.hero-visual {
		background-size: 450px;
		background-repeat: no-repeat;
		background-position: center;
		filter: drop-shadow(0 0 20px rgba(184, 149, 106, 0.3));
		transition: all 0.3s ease;
		min-height: 600px;
	}

	.hero-visual:hover {
		transform: scale(1.05);
		filter: drop-shadow(0 0 30px rgba(184, 149, 106, 0.5));
	}

	@media (max-width: 720px) {
		.hero {
			grid-template-columns: 1fr;
			gap: 2rem;
			text-align: center;
		}

		h1 {
			font-size: 3rem;
		}

		.description {
			max-width: 100%;
		}

		.cta-buttons {
			justify-content: center;
			flex-direction: column;
			align-items: center;
		}

		.btn {
			width: 100%;
			max-width: 280px;
		}

		.hero-visual {
			min-height: 400px;
			background-size: 250px;
		}
	}
</style>
