---
import heroLight from '../assets/hero-gateway.png';
import heroDark from '../assets/kerburos-future-portal.png';
---

<section class="hero">
	<div class="hero-bg hero-bg-dark" id="hero-bg" style={`background-image: url(${heroDark.src});`}></div>
	<div class="hero-bg hero-bg-light" style={`background-image: url(${heroLight.src});`}></div>
	<div class="hero-overlay"></div>

	<div class="hero-body">
		<div class="hero-content" id="hero-content">
			<span class="greeting">The Gateway Stirs</span>
			<h1>tbone<span class="dot">.</span>dev</h1>
			<p class="tagline">Builder of things that matter</p>
			<p class="description">
				I build reliable infrastructure, explore AI, and tinker with Nix systems.
				When I'm not automating something, I'm probably writing about it here.
			</p>
			<div class="cta-buttons">
				<a href="/blog" class="btn btn-primary">Read the Blog</a>
				<a href="/about" class="btn btn-secondary">About Me</a>
			</div>
		</div>
	</div>
</section>

<script>
	const heroBg = document.getElementById('hero-bg') as HTMLElement;
	const heroContent = document.getElementById('hero-content') as HTMLElement;
	const hero = heroBg?.closest('.hero') as HTMLElement;

	function updateParallax() {
		if (!hero || !heroBg || !heroContent) return;
		const rect = hero.getBoundingClientRect();
		if (rect.bottom < 0 || rect.top > window.innerHeight) return;
		const progress = -rect.top;
		heroBg.style.transform = `translateY(${progress * 0.2}px)`;
		heroContent.style.transform = `translateY(${progress * -0.06}px)`;
	}

	const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const isMobile = window.matchMedia('(max-width: 720px)').matches;
	if (!prefersReduced && !isMobile) {
		window.addEventListener('scroll', updateParallax, { passive: true });
		updateParallax();
	}
</script>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background-size: contain;
		background-position: center 15%;
		background-repeat: no-repeat;
		will-change: transform;
		transition: opacity 0.4s ease;
		max-height: 70vh;
	}

	.hero-bg-dark {
		opacity: 1;
	}

	.hero-bg-light {
		opacity: 0;
		background-position: center 15%;
	}

	:root.light .hero-bg-dark {
		opacity: 0;
	}

	:root.light .hero-bg-light {
		opacity: 1;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			160deg,
			rgba(14, 17, 24, 0.1) 0%,
			rgba(14, 17, 24, 0.25) 40%,
			rgba(14, 17, 24, 0.6) 70%,
			rgba(14, 17, 24, 0.92) 100%
		);
		z-index: 1;
		transition: background 0.4s ease;
	}

	:root.light .hero-overlay {
		background: linear-gradient(
			160deg,
			rgba(240, 234, 214, 0.02) 0%,
			rgba(240, 234, 214, 0.15) 40%,
			rgba(240, 234, 214, 0.5) 70%,
			rgba(240, 234, 214, 0.9) 100%
		);
	}

	.hero-body {
		position: relative;
		z-index: 2;
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 10rem 2rem 4rem;
	}

	.hero-content {
		max-width: 680px;
		text-align: center;
		will-change: transform;
		margin-top: auto;
	}

	.greeting {
		font-size: 0.95rem;
		color: var(--accent);
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		display: block;
		margin-bottom: 1rem;
	}

	h1 {
		font-size: 5.5rem;
		font-weight: 700;
		margin: 0 0 0.5rem;
		line-height: 1;
		background: linear-gradient(135deg, #C8783A 0%, #D4A832 60%, #E8C860 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		filter: drop-shadow(0 2px 20px rgba(200, 120, 58, 0.4));
		transition: filter 0.3s ease;
	}

	:root.light h1 {
		background: linear-gradient(135deg, #8B4513 0%, #A85C28 60%, #C8783A 100%);
		-webkit-background-clip: text;
		background-clip: text;
		filter: drop-shadow(0 2px 20px rgba(139, 69, 19, 0.3));
	}

	.dot {
		color: rgba(212, 168, 50, 0.8);
	}

	.tagline {
		font-size: 1.3rem;
		color: rgba(237, 228, 200, 0.75);
		margin: 0 0 1.25rem;
		font-style: italic;
		letter-spacing: 0.02em;
		transition: color 0.3s ease;
	}

	:root.light .tagline {
		color: rgba(60, 48, 32, 0.7);
	}

	.description {
		font-size: 1.05rem;
		color: rgba(210, 200, 178, 0.85);
		line-height: 1.75;
		margin: 0 0 2rem;
		max-width: 520px;
		margin-left: auto;
		margin-right: auto;
		transition: color 0.3s ease;
	}

	:root.light .description {
		color: rgba(60, 48, 32, 0.8);
	}

	.cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn {
		padding: 0.8rem 2.25rem;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.2s ease;
		letter-spacing: 0.03em;
	}

	.btn-primary {
		background: var(--accent);
		color: #0E1118;
		border: 1px solid rgba(212, 168, 50, 0.4);
		box-shadow: 0 4px 20px rgba(200, 120, 58, 0.35);
	}

	.btn-primary:hover {
		background: var(--accent-dark);
		color: #0E1118;
		transform: translateY(-2px);
		box-shadow: 0 6px 28px rgba(200, 120, 58, 0.55);
	}

	.btn-secondary {
		background: rgba(237, 228, 200, 0.07);
		color: rgba(237, 228, 200, 0.85);
		border: 1px solid rgba(237, 228, 200, 0.25);
		backdrop-filter: blur(4px);
	}

	.btn-secondary:hover {
		background: rgba(237, 228, 200, 0.14);
		border-color: rgba(237, 228, 200, 0.4);
		transform: translateY(-2px);
	}

	:root.light .btn-secondary {
		background: rgba(60, 48, 32, 0.07);
		color: rgba(60, 48, 32, 0.85);
		border-color: rgba(60, 48, 32, 0.25);
	}

	:root.light .btn-secondary:hover {
		background: rgba(60, 48, 32, 0.14);
		border-color: rgba(60, 48, 32, 0.4);
	}

	@media (max-width: 720px) {
		.hero {
			min-height: 100svh;
		}

		.hero-bg {
			background-position: center 10%;
			max-height: 55vh;
		}

		.hero-body {
			padding: 8rem 1.5rem 4rem;
			align-items: flex-end;
		}

		.hero-content {
			text-align: left;
		}

		.cta-buttons {
			justify-content: flex-start;
		}

		h1 {
			font-size: 3.5rem;
		}

		.btn {
			width: 100%;
			max-width: 260px;
			text-align: center;
		}
	}
</style>
