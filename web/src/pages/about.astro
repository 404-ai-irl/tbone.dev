---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<section class="about-content">
				<p>
					Hi there! I'm <strong>tbone</strong> — a software developer passionate about
					building things with code. This blog is my digital garden where I share
					what I'm learning, what I'm building, and what I'm thinking about in the
					world of technology.
				</p>

				<div class="philosophy-code">
					<p class="code-intro">This is how I think about my work:</p>
					<div class="code-window">
						<div class="code-header">
							<div class="dot red"></div>
							<div class="dot yellow"></div>
							<div class="dot green"></div>
							<span class="filename">hello.ts</span>
						</div>
						<pre class="code-content"><code><span class="keyword">const</span> <span class="variable">developer</span> = <span class="string">'tbone'</span>;
<span class="keyword">const</span> <span class="variable">passions</span> = [
  <span class="string">'clean code'</span>,
  <span class="string">'systems design'</span>,
  <span class="string">'open source'</span>,
];

<span class="comment">// Always learning...</span>
<span class="keyword">while</span> (<span class="variable">alive</span>) <span class="variable">learn</span>();</code></pre>
					</div>
				</div>

				<h2>What I Write About</h2>
				<ul>
					<li><strong>Web Development</strong> — Frontend, backend, and everything in between</li>
					<li><strong>Programming Languages</strong> — TypeScript, Python, Go, and more</li>
					<li><strong>Tools & Workflows</strong> — The tools that make development enjoyable</li>
					<li><strong>Software Engineering</strong> — Architecture, patterns, and best practices</li>
				</ul>

				<h2>Technologies I Enjoy</h2>
				<p>
					I work with a variety of technologies depending on the project. Some of my 
					favorites include:
				</p>
				<div class="tech-tags">
					<span class="tag">TypeScript</span>
					<span class="tag">React</span>
					<span class="tag">Astro</span>
					<span class="tag">Node.js</span>
					<span class="tag">Python</span>
					<span class="tag">Go</span>
					<span class="tag">Docker</span>
					<span class="tag">Kubernetes</span>
				</div>

				<h2>Get in Touch</h2>
				<p>
					I'd love to hear from you! Whether you have a question about something I wrote, 
					want to collaborate on a project, or just want to say hi — feel free to reach out.
				</p>
				<p>
					You can find me on <a href="https://github.com">GitHub</a>, 
					<a href="https://twitter.com">Twitter</a>, or 
					<a href="https://linkedin.com">LinkedIn</a>. 
					You can also subscribe to my <a href="/rss.xml">RSS feed</a> to stay updated 
					with new posts.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 2em 1em;
	}
	h1 {
		font-size: 2.5em;
		margin-bottom: 0.5em;
	}
	h2 {
		font-size: 1.5em;
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}
	p {
		font-size: 1.1em;
		line-height: 1.6;
		margin-bottom: 1em;
		color: rgb(var(--gray-dark));
	}
	ul {
		margin: 1em 0;
		padding-left: 1.5em;
	}
	li {
		margin-bottom: 0.5em;
		color: rgb(var(--gray-dark));
	}
	.tech-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin: 1em 0;
	}
	.tag {
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
		padding: 0.3em 0.8em;
		border-radius: 4px;
		font-size: 0.9em;
		font-family: monospace;
	}
	a {
		color: var(--accent);
		text-decoration: underline;
	}
	a:hover {
		color: var(--accent-dark);
	}

	.philosophy-code {
		margin: 2em 0;
	}

	.code-intro {
		font-size: 1rem;
		color: rgb(var(--gray));
		font-style: italic;
		margin-bottom: 1em;
	}

	.code-window {
		/* Deep Blue from TheRoyalOrphan code block spec */
		background: #1A3A52;
		border-radius: 12px;
		box-shadow: var(--box-shadow);
		overflow: hidden;
		max-width: 500px;
		margin: 0 auto;
		border: 1px solid rgba(184, 149, 106, 0.2); /* Bronze border hint */
	}

	.code-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1rem;
		background: #0F2438; /* Darker Deep Blue */
		border-bottom: 1px solid rgba(184, 149, 106, 0.25); /* Bronze divider */
	}

	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
	}

	/* Traffic lights mapped to DIVINE palette */
	.red    { background: #C41E3A; } /* Cardinal */
	.yellow { background: #D4AF37; } /* Gold */
	.green  { background: #50C878; } /* Emerald */

	.filename {
		margin-left: auto;
		font-size: 0.85rem;
		color: #708090; /* Slate */
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
	}

	.code-content {
		padding: 1.5rem;
		margin: 0;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		font-size: 0.9rem;
		line-height: 1.6;
		color: #FFFFF0; /* Ivory — base text */
	}

	/* TheRoyalOrphan syntax mapping */
	.code-content .keyword  { color: #D4AF37; } /* Gold   — keywords */
	.code-content .variable { color: #C0C0C0; } /* Ash    — variables */
	.code-content .string   { color: #B8956A; } /* Bronze — strings */
	.code-content .comment  { color: #708090; } /* Slate  — comments */

	@media (max-width: 720px) {
		.code-window {
			max-width: 100%;
		}
	}
</style>
